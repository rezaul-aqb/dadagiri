Options -MultiViews
RewriteEngine On
RewriteBase /dadagiri/

# ── Route all API requests (including OPTIONS) to index.php ──
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Let uploads serve directly
RewriteRule ^uploads/ - [L]

# Serve existing files and directories as-is (assets, logo, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# All other paths → React SPA
RewriteRule ^ index.html [L]
